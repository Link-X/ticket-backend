<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ticket.core.mapper.UserRoleMapper">

    <!-- 用户角色结果映射 -->
    <resultMap id="UserRoleResultMap" type="com.ticket.core.domain.entity.UserRole">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="role" property="role"/>
    </resultMap>

    <!-- 插入用户角色 -->
    <insert id="insert" parameterType="com.ticket.core.domain.entity.UserRole">
        INSERT INTO user_role (user_id, role)
        VALUES (#{userId}, #{role})
    </insert>

    <!-- 根据用户 ID 查询角色列表 -->
    <select id="selectByUserId" resultMap="UserRoleResultMap">
        SELECT id, user_id, role
        FROM user_role
        WHERE user_id = #{userId}
    </select>

</mapper>
